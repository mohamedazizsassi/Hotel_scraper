# Example environment variables for the ml/ module (safe to commit).
# Copy to ml/.env and fill in real values.

# MongoDB — source of raw scraped hotel price records.
MONGO_URI=mongodb://localhost:27017
MONGO_DB=hotel_scraper
MONGO_COLLECTION=hotel_prices

# Optional Mongo timeouts
MONGO_SERVER_SELECTION_TIMEOUT_MS=3000
MONGO_CONNECT_TIMEOUT_MS=3000
MONGO_SOCKET_TIMEOUT_MS=5000

# PostgreSQL — destination for engineered features and platform tables.
#
# POSTGRES_URI is the canonical connection string consumed by ml/ code
# (libpq URI format). Portable across managed Postgres providers (RDS,
# Supabase, Neon) and local dev. Prefer editing this single var.
#
# The discrete vars below mirror the URI for tools that still expect them
# (e.g. psql shell helpers, backend services). Keep them in sync manually.
POSTGRES_URI=postgresql://revway:change_me@localhost:5432/revway

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=revway
POSTGRES_USER=revway
POSTGRES_PASSWORD=change_me
